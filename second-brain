#!/bin/bash
# Second Brain Skill 主入口 - v2.1
# Usage: second-brain <command> [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

show_help() {
    cat << 'EOF'
Second Brain Processor v2.1 🧠 - 知识整理系统

Usage: second-brain <command> [options]

Commands:
  collect              收集昨日原始对话（5:00任务）
  report               生成复盘报告（8:30任务）
  process              运行四步法深度整理
  article <url>        处理文章链接
  queue <input>        处理队列响应
  sync                 同步到GitHub
  help                 显示帮助

Examples:
  second-brain collect              # 收集对话
  second-brain process              # 运行四步法
  second-brain article <url>        # 处理文章
  second-brain sync                 # GitHub同步

Queue Response Commands:
  整理                 触发四步法整理
  AI自动整理           AI自动处理
  推迟 X小时            推迟处理时间
  跳过                 跳过当前任务
EOF
}

case "${1:-}" in
    collect|raw)
        python3 collect_raw_conversations.py
        ;;
    report|daily)
        python3 daily_complete_report.py
        ;;
    process|run)
        shift
        python3 run_four_step_process.py "$@"
        ;;
    article|link)
        shift
        python3 article_handler.py "$@"
        ;;
    queue|handle)
        shift
        python3 queue_response_handler.py "$@"
        ;;
    sync|git)
        cd /root/.openclaw/workspace/obsidian-vault
        git add -A
        git commit -m "sync: $(date '+%Y-%m-%d %H:%M:%S')" || true
        git push origin main
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        echo "Unknown command: ${1:-}"
        show_help
        exit 1
        ;;
esac
